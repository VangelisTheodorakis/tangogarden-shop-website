    "custom_liquid_bGYqkG": {
      "type": "custom-liquid",
      "name": "How it works",
      "settings": {
        "custom_liquid": "<section id=\"why-choose-garden\" style=\"background: white; padding: 20px 20px;\">\n  \n  <div class=\"container\" style=\"max-width: 1200px; margin: 0 auto;\">\n    \n    <div style=\"text-align: center; margin-bottom: 60px;\">\n      <div style=\"font-size: 14px; text-transform: uppercase; letter-spacing: 2px; color: #4E5D22; font-weight: 600; margin-bottom: 20px;\">\n        What Makes Us Different\n      </div>\n      <h2 style=\"font-size: 42px; font-weight: 700; color: #4E5D22; margin-bottom: 30px; line-height: 1.2;\">\n        Why People Choose This Garden\n      </h2>\n      <p style=\"font-size: 20px; color: #666; max-width: 700px; margin: 0 auto; line-height: 1.6;\">\n        Not about perfection. About finding your people through tango.\n      </p>\n    </div>\n    \n    <div class=\"features-grid\">\n      \n      <div class=\"feature-item\">\n        <div class=\"feature-check\">✓</div>\n        <div>\n          <h3 style=\"font-size: 20px; color: #4E5D22; margin-bottom: 8px; font-weight: 700;\">No Partner Needed</h3>\n          <p style=\"font-size: 16px; line-height: 1.6; color: #666; margin: 0;\">\n            We make sure that our classes are role balanced.\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"feature-item\">\n        <div class=\"feature-check\">✓</div>\n        <div>\n          <h3 style=\"font-size: 20px; color: #4E5D22; margin-bottom: 8px; font-weight: 700;\">Welcome Circle</h3>\n          <p style=\"font-size: 16px; line-height: 1.6; color: #666; margin: 0;\">\n            In every class we explore our expectations and goals.\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"feature-item\">\n        <div class=\"feature-check\">✓</div>\n        <div>\n          <h3 style=\"font-size: 20px; color: #4E5D22; margin-bottom: 8px; font-weight: 700;\">Garden Ambassadors</h3>\n          <p style=\"font-size: 16px; line-height: 1.6; color: #666; margin: 0;\">\n            Someone will greet you — you'll never stand alone\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"feature-item\">\n        <div class=\"feature-check\">✓</div>\n        <div>\n          <h3 style=\"font-size: 20px; color: #4E5D22; margin-bottom: 8px; font-weight: 700;\">Group meetups</h3>\n          <p style=\"font-size: 16px; line-height: 1.6; color: #666; margin: 0;\">\n            Make real connections over food and common interests\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"feature-item\">\n        <div class=\"feature-check\">✓</div>\n        <div>\n          <h3 style=\"font-size: 20px; color: #4E5D22; margin-bottom: 8px; font-weight: 700;\">Boundaries Respected</h3>\n          <p style=\"font-size: 16px; line-height: 1.6; color: #666; margin: 0;\">\n            Always, no exceptions — your comfort is non-negotiable\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"feature-item\">\n        <div class=\"feature-check\">✓</div>\n        <div>\n          <h3 style=\"font-size: 20px; color: #4E5D22; margin-bottom: 8px; font-weight: 700;\">Your Choice of Role</h3>\n          <p style=\"font-size: 16px; line-height: 1.6; color: #666; margin: 0;\">\n            Lead, follow, or both — you decide, not your gender\n          </p>\n        </div>\n      </div>\n      \n    </div>\n    \n    <div class=\"bottom-cta-container\">\n      <h3 style=\"font-size: 28px; margin-bottom: 20px; font-weight: 700;\">\n        Want to Know More?\n      </h3>\n      <a href=\"/pages/the-garden#philosophy\" class=\"pathway-style-button\">\n        <p style=\"font-size: 18px; line-height: 1.7; margin:20px 20px\">\n          Read about the stories, the people and experiences that shaped Tango Garden.\n        </p>\n      </a>\n    </div>\n    \n  </div>\n</section>\n\n<style>\n  /* 1. Features Grid Layout */\n  .features-grid {\n    display: grid; \n    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); \n    gap: 35px; \n    margin-bottom: 60px;\n  }\n\n  /* 2. Individual Feature Card */\n  .feature-item {\n    display: flex; \n    align-items: start; \n    gap: 20px; \n    padding: 25px; \n    background: #F3EDE1; \n    border-radius: 12px; \n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n  }\n\n  /* Feature Hover Effect */\n  .feature-item:hover {\n    transform: translateY(-5px);\n    box-shadow: 0 8px 25px rgba(45, 80, 22, 0.15);\n  }\n\n  /* 3. The White Checkmark Fix */\n.feature-check {\n  flex-shrink: 0; \n  width: 50px; \n  height: 50px; \n  background: #4E5D22; \n  border-radius: 50%; \n  display: flex; \n  align-items: center; \n  justify-content: center; \n  font-size: 24px;\n  color: white !important;\n  \n  /* UX FIX: Align with the first line of the title */\n  margin-top: 4px; \n}\n\n  /* 4. Bottom CTA Container */\n  .bottom-cta-container {\n    text-align: center; \n    padding: 50px 40px; \n    background: linear-gradient(135deg, #4E5D22 0%, #5a8a2d 100%); \n    border-radius: 12px; \n    color: white;\n  }\n\n  /* 5. The Button Hover (Matching your previous pathway CSS) */\n  .pathway-style-button {\n    display: inline-block; \n    background: white; \n    color: #4E5D22; \n    border-radius: 8px; \n    text-decoration: none; \n    font-weight: 600; \n    transition: all 0.3s ease;\n    border: 1px solid transparent;\n  }\n\n  .pathway-style-button:hover {\n    background: rgba(255,255,255,0.15) !important;\n    color: white !important;\n    transform: scale(1.02);\n  }\n\n  /* 6. Mobile Responsive Adjustments */\n  @media (max-width: 968px) {\n    #why-choose-garden {\n      padding: 60px 20px !important;\n    }\n    \n    #why-choose-garden h2 {\n      font-size: 32px !important;\n    }\n    \n    .features-grid {\n      grid-template-columns: 1fr !important;\n      gap: 25px !important;\n    }\n\n    .feature-item {\n      padding: 20px !important;\n    }\n\n    .pathway-style-button {\n      display: block !important;\n      margin: 0 !important;\n      width: 100%;\n    }\n  }\n/* Mobile-first UX refinements */\n@media (max-width: 768px) {\n  /* 1. Adjust Section Padding for tighter mobile screens */\n  #why-choose-garden {\n    padding: 60px 16px !important;\n  }\n\n  /* 2. Scale down the checkmark container so text has more room */\n  .feature-check {\n    width: 36px !important;  /* Reduced from 50px */\n    height: 36px !important; /* Reduced from 50px */\n    font-size: 18px !important; /* Slightly smaller check */\n    margin-top: 2px; /* Precision alignment with the first line of text */\n  }\n\n  /* 3. Tighten the gap between icon and text */\n  .feature-item {\n    gap: 16px !important;\n    padding: 20px !important;\n    align-items: flex-start !important; /* Ensure icon stays at top */\n  }\n\n  /* 4. Text alignment polish */\n  .feature-item h3 {\n    font-size: 18px !important;\n    margin-bottom: 4px !important;\n  }\n  \n  .feature-item p {\n    font-size: 15px !important;\n    line-height: 1.5 !important;\n  }\n\n  /* 5. CTA Polish - Full width but less bulky */\n  .bottom-cta-container {\n    padding: 40px 24px !important;\n  }\n}\n</style>",
