    "custom_liquid_Yy9gVW": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Testimonies",
      "settings": {
        "custom_liquid": "<div class=\"social-proof-section\" style=\"background: #F3EDE1; padding: 20px 20px;\">\n  <div class=\"container\" style=\"max-width: 1200px; margin: 0 auto;\">\n    \n    <h2 style=\"text-align: center; font-size: 36px; margin-bottom: 20px; color: #4E5D22;\">\n      Real People, Real Stories\n    </h2>\n    \n    <p style=\"text-align: center; font-size: 18px; color: #666; margin-bottom: 60px; max-width: 600px; margin-left: auto; margin-right: auto;\">\n      Every person in our garden started exactly where you are: curious, maybe nervous, definitely ready for something real.\n    </p>\n    \n    <div class=\"testimonial-grid\" style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;\">\n      \n      <!-- Testimonial 1 -->\n      <div class=\"testimonial-card\" style=\"background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);\">\n        <div class=\"quote-mark\" style=\"font-size: 48px; color: #4E5D22; line-height: 1;\">&quot;</div>\n        <p style=\"font-size: 16px; line-height: 1.6; color: #333; margin: 20px 0;\">\n          I came alone and terrified. Left with three new friends and actually looking forward to the next class. Wild.\n        </p>\n        <div class=\"author\" style=\"display: flex; align-items: center; margin-top: 20px;\">\n          <img src=\"URL_TO_PHOTO\" style=\"width: 50px; height: 50px; border-radius: 50%; margin-right: 15px;\" alt=\"Sarah\">\n          <div>\n            <strong style=\"display: block; color: #4E5D22;\">Sarah, 28</strong>\n            <span style=\"font-size: 14px; color: #999;\">Marketing Manager, Cologne</span>\n          </div>\n        </div>\n      </div>\n      \n      <!-- Testimonial 2 -->\n      <div class=\"testimonial-card\" style=\"background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);\">\n        <div class=\"quote-mark\" style=\"font-size: 48px; color: #4E5D22; line-height: 1;\">&quot;</div>\n        <p style=\"font-size: 16px; line-height: 1.6; color: #333; margin: 20px 0;\">\n          &quot;Two left feet&quot; was an understatement. But the intro session felt like hanging with friends, not a dance class. Now I'm hooked.\n        </p>\n        <div class=\"author\" style=\"display: flex; align-items: center; margin-top: 20px;\">\n          <img src=\"URL_TO_PHOTO\" style=\"width: 50px; height: 50px; border-radius: 50%; margin-right: 15px;\" alt=\"Max\">\n          <div>\n            <strong style=\"display: block; color: #4E5D22;\">Max, 31</strong>\n            <span style=\"font-size: 14px; color: #999;\">Software Developer, Düsseldorf</span>\n          </div>\n        </div>\n      </div>\n      \n      <!-- Testimonial 3 -->\n      <div class=\"testimonial-card\" style=\"background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);\">\n        <div class=\"quote-mark\" style=\"font-size: 48px; color: #4E5D22; line-height: 1;\">&quot;</div>\n        <p style=\"font-size: 16px; line-height: 1.6; color: #333; margin: 20px 0;\">\n          I've lived in Cologne for 3 years and barely knew anyone outside work. This community changed that in 3 weeks.\n        </p>\n        <div class=\"author\" style=\"display: flex; align-items: center; margin-top: 20px;\">\n          <img src=\"URL_TO_PHOTO\" style=\"width: 50px; height: 50px; border-radius: 50%; margin-right: 15px;\" alt=\"Lisa\">\n          <div>\n            <strong style=\"display: block; color: #4E5D22;\">Lisa, 26</strong>\n            <span style=\"font-size: 14px; color: #999;\">Teacher, Bonn</span>\n          </div>\n        </div>\n      </div>\n      \n    </div>\n  </div>\n</div>\n\n<style>\n  @media (max-width: 768px) {\n    .social-proof-section h2 {\n      font-size: 28px !important;\n    }\n    .testimonial-grid {\n      grid-template-columns: 1fr !important;\n    }\n  }\n</style>",
