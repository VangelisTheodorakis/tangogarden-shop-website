      "name": " Three Ways to Enter the Garden ",
      "settings": {
        "custom_liquid": "<!-- Three Ways to Enter the Garden Section -->\n<section id=\"three-ways-to-enter\" style=\"background: white; padding: 20px 20px;\">\n  \n  <div class=\"container\" style=\"max-width: 1200px; margin: 0 auto;\">\n    \n    <!-- Section Header -->\n    <div style=\"text-align: center; margin-bottom: 80px;\">\n      <div style=\"font-size: 14px; text-transform: uppercase; letter-spacing: 2px; color: #4E5D22; font-weight: 600; margin-bottom: 20px;\">\n        How to Start\n      </div>\n      <h2 style=\"font-size: 42px; font-weight: 700; color: #4E5D22; margin-bottom: 25px; line-height: 1.2;\">\n        Three Ways to Enter the Garden\n      </h2>\n      <p style=\"font-size: 20px; color: #666; max-width: 700px; margin: 0 auto; line-height: 1.6;\">\n        Choose what feels right for where you are.\n      </p>\n    </div>\n    \n    <!-- Cards Grid -->\n    <div class=\"garden-pathways-grid\" style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;margin-bottom: 30px\">\n      \n      <!-- Door 1: Enter the Garden -->\n      <div class=\"pathway-card\" style=\"background: #F3EDE1; border-radius: 16px; padding: 45px 35px; text-align: center; transition: all 0.3s ease; position: relative; overflow: hidden; display: flex; flex-direction: column;\">\n        \n        <!-- Card Number Badge -->\n        <div style=\"position: absolute; top: -15px; right: -15px; width: 80px; height: 80px; background: rgba(45,80,22,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: 700; color: rgba(45,80,22,0.15);\">\n          1\n        </div>\n        \n        <!-- Icon -->\n        <div style=\"width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; font-size: 32px; box-shadow: 0 4px 15px rgba(0,0,0,0.08);\">\n          🌱\n        </div>\n        \n        <!-- Content -->\n        <h3 style=\"font-size: 26px; color: #4E5D22; margin-bottom: 15px; font-weight: 700;\">\n          Enter the Garden\n        </h3>\n        \n        <p style=\"font-size: 16px; line-height: 1.7; color: #666; margin-bottom: 25px;\">\n          One-time event for those who want to try without commitment.\n        </p>\n        \n        <!-- Features -->\n        <ul style=\"list-style: none; padding: 0; margin: 0 0 30px 0; text-align: left;\">\n          <li style=\"font-size: 14px; color: #555; margin-bottom: 10px; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: #4E5D22; font-weight: 700;\">✓</span>\n            One-time 1.5 hour session \n          </li>\n          <li style=\"font-size: 14px; color: #555; margin-bottom: 10px; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: #4E5D22; font-weight: 700;\">✓</span>\n            Connect with new people\n          </li>\n          <li style=\"font-size: 14px; color: #555; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: #4E5D22; font-weight: 700;\">✓</span>\n            Drinks & snacks included\n          </li>\n        </ul>\n<div style=\"margin-bottom: 25px; padding: 12px; background: rgba(45,80,22,0.05); border-radius: 8px; display: flex; align-items: center; gap: 8px;\">\n  <span style=\"font-size: 16px;\">🗓️</span>\n  <div style=\"text-align: left;\">\n    <span style=\"display: block; font-size: 11px; text-transform: uppercase; color: #4E5D22; font-weight: 700;\">Next Event</span>\n    <span style=\"font-size: 15px; font-weight: 600; color: #4E5D22;\">\n{% assign product_ref = all_products['enter-the-garden-general-admission'] %}\n\n{%- render 'date-logic', \n    start_list: product_ref.metafields.custom.event_start, \n    end_list: product_ref.metafields.custom.event_end ,\nshow_mode:\"first\"\n-%}\n    </span>\n  </div>\n</div>    \n        <!-- Price & CTA - Takes remaining space -->\n        <div id=\"target\" style=\" border-top: 2px solid rgba(45,80,22,0.1); flex-grow: 1; display: flex; flex-direction: column;\">\n          <div style=\"flex-grow: 1; display: flex; flex-direction: column; justify-content: flex-end;\">\n            <p style=\"font-size: 32px; font-weight: 700; color: #4E5D22; margin-bottom: 15px;\">\n              10€ or 8€ *\n            </p>\n          </div>\n          <a href=\"/products/enter-the-garden-general-admission\" style=\"display: block; background: white; color: #4E5D22; padding: 15px 30px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 16px; border: 2px solid #4E5D22; transition: all 0.3s ease;\">\n            Start small →\n          </a>\n        </div>\n      </div>\n      \n      <!-- Door 2: Intro Session (HIGHLIGHTED) -->\n      <div class=\"pathway-card featured\" style=\"background: linear-gradient(135deg, #4E5D22 0%, #3d6b1f 100%); border-radius: 16px; padding: 45px 35px; text-align: center; transition: all 0.3s ease; position: relative; overflow: hidden; box-shadow: 0 10px 40px rgba(45,80,22,0.3); display: flex; flex-direction: column;\">\n        \n        \n        <!-- Card Number Badge -->\n        <div style=\"position: absolute; top: -15px; right: -15px; width: 80px; height: 80px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: 700; color: rgba(255,255,255,0.2);\">\n          2\n        </div>\n        \n        <!-- Icon -->\n        <div style=\"width: 70px; height: 70px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; font-size: 32px; backdrop-filter: blur(10px);\">\n          🌿\n        </div>\n        \n        <!-- Content -->\n        <h3 style=\"font-size: 26px; color: white; margin-bottom: 15px; font-weight: 700;\">\n          Regular classes\n        </h3>\n        \n        <p style=\"font-size: 16px; line-height: 1.7; color: rgba(255,255,255,0.9); margin-bottom: 25px;\">\n          A steady weekly rhythm for optimal learning and growth.\n        </p>\n        \n        <!-- Features -->\n        <ul style=\"list-style: none; padding: 0; margin: 0 0 30px 0; text-align: left;\">\n          <li style=\"font-size: 14px; color: rgba(255,255,255,0.9); margin-bottom: 10px; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: white; font-weight: 700;\">✓</span>\n            10 weekly 1.5 hour sessions\n          </li>\n          <li style=\"font-size: 14px; color: rgba(255,255,255,0.9); margin-bottom: 10px; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: white; font-weight: 700;\">✓</span>\n            Community events & Rituals\n          </li>\n\n          <li style=\"font-size: 14px; color: rgba(255,255,255,0.9); padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: white; font-weight: 700;\">✓</span>\n           Cover missed classes for free\n          </li>\n\n        </ul>\n        <div style=\"margin: 0 0 25px 0; padding: 10px; background: rgba(255,255,255,0.1); border-radius: 8px; display: flex; align-items: center; gap: 10px; border: 1px solid rgba(255,255,255,0.2);\">\n  <span style=\"font-size: 18px;\">✨</span>\n  <div style=\"text-align: left;font-weight: 600;\">\n    <p style=\"margin: 0; font-size: 10px; text-transform: uppercase; color: rgba(255,255,255,0.8); font-weight: 700;\">Next Class (Course open until 31/03)</p>\n    <p style=\"margin: 0; font-size: 14px; font-weight: 600; color: white;\">\n{%- assign collection_ref = collections['regular-classes'] -%}\n\n{%- render 'date-logic', \n    start_list: collection_ref.metafields.custom.event_start, \n    end_list: collection_ref.metafields.custom.event_end \n-%}</p>\n  </div>\n</div>\n        <!-- Price & CTA - Takes remaining space -->\n        <div style=\" border-top: 2px solid rgba(255,255,255,0.2); flex-grow: 1; display: flex; flex-direction: column;\">\n  <div style=\"flex-grow: 1; display: flex; flex-direction: column; justify-content: flex-end;\">\n    <p style=\"font-size: 32px; font-weight: 700; color: white; margin-bottom: 10px; line-height: 1.1;\">\n      130€ or 100€ *<span style=\"font-size: 16px; font-weight: 400; display: block; margin-top: 5px;\">for the full package</span>\n    </p>\n  <a href=\"/products/the-sprouting-sessions-beginner-level-full-course-pass-general-admission\" style=\"display: block; background: white; color: #4E5D22; padding: 15px 20px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s ease;margin-bottom: 20px;\">\n    Commit to learning →\n  </a>\n      <a href=\"/collections\" style=\"background: transparent; border: 2px solid white; color: white; padding: 10px 8px; border-radius: 8px; text-decoration: none; font-size: 16px; font-weight: 600;\"> or explore our flexible bundles </a>\n  </div>\n    \n</div>\n      </div>\n      \n      <!-- Door 3: Regular Classes -->\n      <div class=\"pathway-card\" style=\"background: #F3EDE1; border-radius: 16px; padding: 45px 35px; text-align: center; transition: all 0.3s ease; position: relative; overflow: hidden; display: flex; flex-direction: column;\">\n        \n        <!-- Card Number Badge -->\n        <div style=\"position: absolute; top: -15px; right: -15px; width: 80px; height: 80px; background: rgba(45,80,22,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: 700; color: rgba(45,80,22,0.15);\">\n          3\n        </div>\n        \n        <!-- Icon -->\n        <div style=\"width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 25px; font-size: 32px; box-shadow: 0 4px 15px rgba(0,0,0,0.08);\">\n          🌳\n        </div>\n        \n        <!-- Content -->\n        <h3 style=\"font-size: 26px; color: #4E5D22; margin-bottom: 15px; font-weight: 700;\">\n          Weekly Practicas\n        </h3>\n        \n        <p style=\"font-size: 16px; line-height: 1.7; color: #666; margin-bottom: 25px;\">\n          A relaxed space to practice, connect, and grow together.\n        </p>\n        \n        <!-- Features -->\n        <ul style=\"list-style: none; padding: 0; margin: 0 0 30px 0; text-align: left;\">\n         <li style=\"font-size: 14px; color: #555; margin-bottom: 10px; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: #4E5D22; font-weight: 700;\">✓</span>\n            Weekly 2.5 hour guided sessions\n          </li>\n<li style=\"font-size: 14px; color: #555; margin-bottom: 10px; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: #4E5D22; font-weight: 700;\">✓</span>\n            Open-level and double-role\n          </li>\n          <li style=\"font-size: 14px; color: #555; padding-left: 25px; position: relative;\">\n            <span style=\"position: absolute; left: 0; color: #4E5D22; font-weight: 700;\">✓</span>\n            Community-focused atmosphere\n          </li>\n        </ul>\n        <div style=\"margin-bottom: 25px; padding: 12px; background: rgba(45,80,22,0.05); border-radius: 8px; display: flex; align-items: center; gap: 8px;\">\n  <span style=\"font-size: 16px;\">🗓️</span>\n  <div style=\"text-align: left;\">\n    <span style=\"display: block; font-size: 11px; text-transform: uppercase; color: #4E5D22; font-weight: 700;\">Next Practica</span>\n    <span style=\"font-size: 15px; font-weight: 600; color: #4E5D22;\">\n{% assign product_ref = all_products['the-garden-practica-1-practica-pass-general-admission'] %}\n\n{%- render 'date-logic', \n    start_list: product_ref.metafields.custom.event_start, \n    end_list: product_ref.metafields.custom.event_end ,\nshow_mode:\"closest\"\n-%}\n    </span>\n  </div>\n</div> \n        <!-- Price & CTA - Takes remaining space -->\n        <div style=\" border-top: 2px solid rgba(45,80,22,0.1); flex-grow: 1; display: flex; flex-direction: column;\">\n          <div style=\"flex-grow: 1; display: flex; flex-direction: column; justify-content: flex-end;\">\n            <p style=\"font-size: 32px; font-weight: 700; color: #4E5D22; margin-bottom: 15px;\">\n              10€ or 8€ *\n            </p>\n          </div>\n          <a href=\"/products/the-garden-practica-1-practica-pass-general-admission\" style=\"display: block; background: white; color: #4E5D22; padding: 15px 30px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 16px; border: 2px solid #4E5D22; transition: all 0.3s ease;\">\n            Accelerate your growth →\n          </a>\n        </div>\n      </div>\n      \n    </div>\n    <div style=\"text-align: center;\">\n    \n  <p style=\"margin: 0px;\"><span> * for students and anyone who is 28 years old or less</span></p>\n    </div>\n    <!-- Bottom Message -->\n    <div style=\"text-align: center; margin-top: 40px; padding: 50px 30px; background: #F9F7F2; border: 1px solid rgba(45,80,22,0.1); border-radius: 20px;\">\n  \n  <h4 style=\"font-size: 22px; color: #4E5D22; margin-bottom: 12px; font-weight: 700;\">\n    Still wandering?\n  </h4>\n  \n  <p style=\"font-size: 16px; line-height: 1.6; color: #666; max-width: 500px; margin: 0 auto 30px;\">\n    Every dancer starts somewhere different. If you’re not sure where you fit, we’re happy to guide you personally.\n  </p>\n\n  <div style=\"display: flex; gap: 15px; justify-content: center; align-items: center; flex-direction: row; flex-wrap: wrap;\">\n    \n    <a href=\"/collections/all\" class=\"safety-btn-info\" style=\"display: inline-flex; align-items: center; padding: 12px 24px; color: #4E5D22; font-weight: 600; text-decoration: none; font-size: 15px; border-radius: 30px; background: rgba(45,80,22,0.05); border: 1px solid rgba(45,80,22,0.1); transition: all 0.2s ease;\">\n      <span style=\"margin-right: 8px;\">📋</span> See all details\n    </a>\n\n    <a href=\"https://wa.me/491602368723?text=Hi! I'm not sure which option is right for me...\" \n       class=\"safety-btn-primary\"\n       style=\"display: inline-flex; align-items: center; padding: 12px 24px; background: #4E5D22; color: white; font-weight: 600; text-decoration: none; font-size: 15px; border-radius: 30px; box-shadow: 0 4px 12px rgba(45,80,22,0.2); transition: all 0.3s ease; border: 1px solid transparent;\">\n      <span style=\"margin-right: 8px;\">💬</span> Chat on WhatsApp\n    </a>\n\n</div>\n</div>\n  </div>\n  \n</section>\n\n<!-- Hover Effects & Mobile Styles -->\n<style>\n  /* Card hover effects */\n  /*.pathway-card {\n    cursor: pointer;\n  }\n  */\n  \n  .pathway-card:not(.featured):hover {\n    transform: translateY(-8px);\n    box-shadow: 0 15px 40px rgba(0,0,0,0.12);\n  }\n  \n  .pathway-card.featured:hover {\n    box-shadow: 0 20px 50px rgba(45,80,22,0.4);\n    transform: translateY(-8px);\n  }\n  \n  .pathway-card a:hover {\n    background: #4E5D22 !important;\n    color: white !important;\n  }\n  \n  .pathway-card.featured a:hover {\n    background: rgba(255,255,255,0.15) !important;\n    color: white !important;\n    border-color: white !important;\n  }\n  \n  /* Mobile responsive */\n  @media (max-width: 968px) {\n    #three-ways-to-enter {\n      padding: 80px 20px !important;\n    }\n    \n    #three-ways-to-enter h2 {\n      font-size: 32px !important;\n    }\n    \n    .garden-pathways-grid {\n      grid-template-columns: 1fr !important;\n      gap: 30px !important;\n    }\n    \n    .pathway-card h3 {\n      font-size: 24px !important;\n    }\n  }\n@media (max-width: 480px) {\n  /* Ensure the container doesn't feel too cramped */\n  .pathway-card {\n    padding: 35px 20px !important;\n  }\n  \n  /* Make the main button text slightly smaller if needed to prevent overflow */\n  .pathway-card a {\n    font-size: 15px !important;\n    padding: 12px 15px !important;\n  }\n\n  /* Ensure the text wraps cleanly without huge gaps */\n  .pathway-card p {\n    font-size: 15px !important;\n  }\n}\n/* Button Hover States */\n.safety-net-btn:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 6px 15px rgba(45,80,22,0.15);\n}\n\n@media (max-width: 600px) {\n  .safety-net-container {\n    padding: 40px 20px !important;\n  }\n  /* Force vertical stack on mobile for clear intent */\n  .safety-net-container .flex-group {\n    flex-direction: column !important;\n  }\n  .safety-net-container a {\n    width: 100%; /* Full width buttons are easier to tap on mobile */\n    justify-content: center;\n  }\n}\n/* \"See all details\" Hover: Subtle fill and border deepening */\n.safety-btn-info:hover {\n  background: rgba(45,80,22,0.12) !important;\n  border-color: rgba(45,80,22,0.3) !important;\n  transform: translateY(-1px);\n}\n\n/* \"WhatsApp\" Hover: Slight lift and glow */\n.safety-btn-primary:hover {\n  background: #3d6b1f !important; /* Lighter shade of your green */\n  transform: translateY(-2px);\n  box-shadow: 0 6px 20px rgba(45,80,22,0.3) !important;\n}\n\n/* Active State: \"Click\" effect when pressed */\n.safety-btn-info:active, .safety-btn-primary:active {\n  transform: translateY(0);\n}\n</style>",
